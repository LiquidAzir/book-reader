# Copy to .env for local dev. On Render, set as environment variables in the dashboard.
PORT=3000

# Postgres connection string. On Render this is provided automatically when you
# link a managed Postgres instance to the service.
DATABASE_URL=postgres://user:pass@localhost:5432/book_reader

# Allowed CORS origins, comma-separated. Use "*" for development.
CORS_ORIGINS=*

# Optional: cap on in-memory book-text cache (per book, bytes won't exceed this many entries)
BOOK_CACHE_MAX_ENTRIES=50
